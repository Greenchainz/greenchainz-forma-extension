# ─────────────────────────────────────────────────────────────────────────────
# GreenChainz Forma Extension — Environment Variables
#
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored and never committed.
#
#   cp .env.example .env.local
# ─────────────────────────────────────────────────────────────────────────────

# Base URL for the GreenChainz public API.
# Defaults to https://greenchainz.com if not set.
# Override this when pointing at a staging or local API server.
#
#   Local API server : http://localhost:3001
#   Staging          : https://staging.greenchainz.com
#   Production       : https://greenchainz.com  (default)
VITE_GC_API_URL=https://greenchainz.com

# Extension ID registered in the Autodesk Platform Services (APS) portal.
# The value below is the development extension ID — replace with your own
# if you create a new extension in the APS portal.
VITE_FORMA_EXTENSION_ID=6f4142af-4d9f-404d-9d1a-00791e9c7c24

# Forma environment the extension is loaded into.
# Matches the panel URLs configured in package.json → "forma" → "panels".
#   local      : http://localhost:5000  (pnpm run dev)
#   staging    : your staging domain
#   production : your production domain
VITE_FORMA_ENV=local

# ─── Notes ────────────────────────────────────────────────────────────────────
# • All variables exposed to the browser must start with VITE_
# • In development (pnpm run dev) the app uses mock material data and a stubbed
#   Forma SDK automatically — no live API or Autodesk Forma account is needed.
# • In production the real GreenChainz API is called and the extension must be
#   loaded inside Autodesk Forma for SDK features (selection, area metrics,
#   floating panels, extension storage) to work.
