# GreenChainz Forma Extension — env vars
# Copy to .env.local and fill in

# GreenChainz API base URL
# Local dev: http://localhost:3001
# Production: https://api.greenchainz.com
VITE_GC_API_URL=http://localhost:3001

# Extension ID (from APS portal)
# Used for Forma SDK registration
VITE_FORMA_EXTENSION_ID=6f4142af-4d9f-404d-9d1a-00791e9c7c24

# Forma environment
# local: http://localhost:8081
# staging: https://forma.staging.greenchainz.com
# production: https://forma.greenchainz.com
VITE_FORMA_ENV=local

