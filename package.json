{
  "name": "greenchainz-forma-extension",
  "version": "0.1.0",
  "description": "GreenChainz Autodesk Forma Extension — EPD-verified material sourcing and carbon analysis inside Forma Building Design",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.json\" \"*.md\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"*.json\" \"*.md\""
  },
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@azure/monitor-opentelemetry": "^1.16.0",
    "forma-embedded-view-sdk": "^0.93.0",
    "preact": "^10.28.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.2",
    "@testing-library/preact": "^3.2.4",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitest/ui": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.5"
  },
  "forma": {
    "extensions": [
      {
        "id": "6f4142af-4d9f-404d-9d1a-00791e9c7c24",
        "name": "GreenChainz Materials",
        "description": "EPD-verified sustainable material sourcing, Material Credit Scores, and one-click RFQ — alongside Forma Carbon Insights.",
        "panels": [
          {
            "type": "leftPanelExtension",
            "url": "http://localhost:8081/left.html"
          },
          {
            "type": "rightPanelExtension",
            "url": "http://localhost:8081/right.html"
          }
        ]
      }
    ]
  }
}